{% extends 'base.html.twig' %}
{% block principal %}
	<h1>Imagen index</h1>

	<form action="{{ path('app_imagen_index_busqueda') }}" method="post">
		<label>Búsqueda:</label>
		<input type="text" name="busqueda" id="busqueda" value="{{ busqueda | default('') }}">
		<input type="date" name="fechaInicial" id="fechaInicial" value="{{ fechaInicial | default('') }}">
		<input type="date" name="fechaFinal" id="fechaFinal" value="{{ fechaFinal | default('') }}">
		<input type="submit" value="Buscar">
		<a href="{{ path('app_imagen_index') }}" class="btn btn-success" style="border: 1px solid black; color: black;">Limpiar</a>
	</form>

	{% for message in app.flashes('mensaje') %}
		<div class="alert alert-primary" role="alert">
			{{ message }}
		</div>
	{% endfor %}

	<table class="table">
		<thead>
			<tr>
				<th>
					<a href="{{ path("app_imagen_index_ordenado", {ordenacion: 'id'}) }}">ID</a>
				</th>
				<th>Imagen</th>
				<th>Nombre</th>
				<th>
					<a href="{{ path("app_imagen_index_ordenado", {ordenacion: 'descripcion'}) }}">Descripción</a>
				</th>
				<th>
					<a href="{{ path("app_imagen_index_ordenado", {ordenacion: 'categoria'}) }}">Categoria</a>
				</th>
				<th>Fecha de creación</th>
				<th>NumVisualizaciones</th>
				<th>NumLikes</th>
				<th>NumDownloads</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
			{% for imagen in imagens %}
				<tr>
					<td>{{ imagen.id }}</td>
					<td><img style="height: 100px; width: 200px; border-radius: 10px" src="{{ images_directory~asset(imagen.nombre) }}" alt="{{ imagen.nombre }}"/></td>
					<td>{{ imagen.nombre }}</td>
					<td>{{ imagen.descripcion }}</td>
					<td>{{ imagen.categoria }}</td>
					<td>{{ imagen.fecha | date('d/m/Y') }}</td>
					<td>{{ imagen.numVisualizaciones }}</td>
					<td>{{ imagen.numLikes }}</td>
					<td>{{ imagen.numDownloads }}</td>
					<td class="btn btn-primary" style="border: 1px solid black;">
						<a style="color: black" href="{{ path('app_imagen_show', {'id': imagen.id}) }}">MOSTRAR</a>
					</td>
					<td class="btn btn-warning" style="border: 1px solid black;">
						<a style="color: black" href="{{ path('app_imagen_edit', {'id': imagen.id}) }}">EDITAR</a>
					</td>
					<td class="btn btn-danger" style="border: 1px solid black;">
						<a style="color: black" href="{{ path('app_imagen_delete_json', {'id': imagen.id}) }}" class="delete">BORRAR</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="8">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a class="btn btn-info" style="color: black; width: 150px; height: 35px; border: 1px solid black;" href="{{ path('app_imagen_new') }}">CREAR NUEVO</a>
{% endblock %}
