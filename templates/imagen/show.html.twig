{% extends 'base.html.twig' %}
{% block principal %}
    <h1>Imagen</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ imagen.id }}</td>
            </tr>
            <tr>
                <th>Imagen</th>
				<td><img style="height: 100px; width: 200px; border-radius: 10px" src="{{ asset(imagen.getUrlSubidas()) }}"/></td>
            </tr>
            <tr>
                <th>Nombre</th>
                <td>{{ imagen.nombre }}</td>
            </tr>
            <tr>
                <th>Descripcion</th>
                <td>{{ imagen.descripcion }}</td>
            </tr>
            <tr>
                <th>Categoria</th>
                <td>{{ imagen.categoria }}</td>
            </tr>
            <tr>
                <th>NumVisualizaciones</th>
                <td>{{ imagen.numVisualizaciones }}</td>
            </tr>
            <tr>
                <th>NumLikes</th>
                <td>{{ imagen.numLikes }}</td>
            </tr>
            <tr>
                <th>NumDownloads</th>
                <td>{{ imagen.numDownloads }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn btn-info" style="color: black; width: 150px; height: 35px; border: 1px solid black;" href="{{ path('app_imagen_index') }}">VOLVER ATRÁS</a>

    <a class="btn btn-info" style="color: black; width: 150px; height: 35px; border: 1px solid black;" href="{{ path('app_imagen_edit', {'id': imagen.id}) }}">EDITAR</a>

    {{ include('imagen/_delete_form.html.twig') }}
{% endblock %}
