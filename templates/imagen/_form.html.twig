{{ form_start(form) }}
<div class="container">
	<div class="my-custom-class-for-errors">
		{{ form_errors(form) }}
	</div>

	{# Fila para NOMBRE (Ancho completo 12) #}
	<div class="row">
		<div class="col-md-12">
			{{ form_row(form.nombre, {'label':'Nombre:','label_attr': {
                'class':'etiqueta'
            } }) }}
		</div>
	</div>

	{# Fila para CATEGORÍA (Ancho completo 12) #}
	<div class="row">
		<div
			class="col-md-12">
			{# He añadido 'attr': {'class': 'form-control'} por seguridad, 
			               para forzar que el select ocupe el 100% del ancho #}
			{{ form_row(form.categoria, {
                'label':'Categoría:',
                'label_attr': {'class':'etiqueta'},
                'attr': {'class': 'form-control'} 
            }) }}
		</div>
	</div>

	{# Fila para DESCRIPCIÓN #}
	<div class="row">
		<div class="col-md-12">
			{{ form_row(form.descripcion, {'label':'Descripción:','label_attr': {
                'class':'etiqueta'
            }}) }}
		</div>
	</div>

	{# Fila para PASSWORD #}
	<div class="row">
		<div class="col-md-12">
			{{ form_row(form.password) }}
		</div>
	</div>

	<br>

	{# Botón y cierre #}
	<div class="row">
		<button class="btn">{{ button_label|default('Save') }}</button>
		{{ form_end(form) }}
	</div>
</div>
