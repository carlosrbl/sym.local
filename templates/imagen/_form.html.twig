{{ form_start(form) }}
<div class="container">
	<div class="my-custom-class-for-errors">
		{{ form_errors(form) }}
	</div>
	<div class="row">
		<div class="col-md-8">
			{{ form_row(form.nombre, {'label':'Nombre:','label_attr': {
 'class':'etiqueta'
 } }) 
}}
		</div>
		<div class="col-md-4">
			{{ form_row(form.categoria, {'label':'Categoría:','label_attr': {
 'class':'etiqueta'
 }}) }}
		</div>
	</div>
	<div class="row">
		<div class="col-md-12">
			{{ form_row(form.descripcion, {'label':'Descripción:','label_attr': {
 'class':'etiqueta'
 }}) }}
		</div>
	</div>
	<div class="row">
		<div class="col-md-12">
			{{ form_row(form.password) }}
		</div>
	</div>
	<div class="row">
		<button class="btn">{{ button_label|default('Save') }}</button>
		{{ form_end(form) }}
	</div>
</div>
