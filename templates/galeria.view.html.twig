{% extends 'base.html.twig' %}
{% block principal %}
	<div class="hero hero-inner">
		<div class="container">
			<div class="row align-items-center">
				<div class="col-lg-6 mx-auto text-center">
					<div class="intro-wrap">
						<h1 class="mb-0">Galería</h1>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- Principal Content Start -->
	<div id="galeria">
		<div class="container">
			<div class="col-xs-12 col-sm-8 col-sm-push-2" style="width: 850px;">
				<button class="btn btn-primary" style="border: 1px solid black;">
					<a href='/exposiciones/crear' style="color: white;">
						<i class="fa fa-book"></i>
						Crear Exposición
					</a>
				</button>
				<h2>Subir imágenes:</h2>
				<hr>
				<!-- Formulario que permite subir una imagen con su descripción -->
				<!-- Hay que indicar OBLIGATORIAMENTE enctype="multipart/form-data" para enviar ficheros al servidor -->
					<form clas="form-horizontal" action="/galeria/nueva" method="post" enctype="multipart/form-data"> <div class="form-group">
						<div class="col-xs-12">
							<label class="label-control">Imagen</label>
							<input class="form-control-file" type="file" name="imagen">
						</div>
					</div>
					<div class="form-group">
						<div class="col-xs-12">
							<label class="label-control">Categoria</label>
							<select class="form-control" name="categoria">
								{% for categoria in categorias %}
									<option value="{{ categoria.getId() }}">{{ categoria.getNombre() }}</option>
								{% endfor %}
							</select>
							<label class="label-control">Titulo</label>
							<input required type="text" class="form-control" id="titulo" name="titulo">
							<label class="label-control">Descripción</label>
							<textarea required class="form-control" name="descripcion"></textarea>
							<br>
							<button class="pull-right btn btn-lg sr-button">ENVIAR</button>
							<br><br><br><br>
						</div>
					</div>
				</form>
				<hr class="divider">
				<div class="imagenes_galeria">
					<table class="table">
						<thead>
							<tr>
								<th scope="col">#</th>
								<th scope="col">Imagen</th>
								<th scope="”col”">Categoria</th>
								<th scope="col">Visualizaciones</th>
								<th scope="col">Likes</th>
								<th scope="col">Descargas</th>
							</tr>
						</thead>
						<tbody>
							{% for imagen in imagenes %}
								<tr>
									<th scope="row">
										<a href="{{ path('app_imagen_show', {id:imagen.getId()}) }}">
											{{ imagen.getNombre() }}</a>
									</th>
									<td>
										<img src="{{ asset(imagen.getUrlSubidas()) }}" alt="{{ imagen.getDescripcion() }}" title="{{ imagen.getDescripcion() }}" width="100px">
									</td>
									<td>{{ imagen.getCategoria() }}</td>
									<td>{{ imagen.getNumVisualizaciones() }}</td>
									<td>{{ imagen.getNumLikes() }}</td>
									<td>{{ imagen.getNumDownloads() }}</td>
									<td class="btn btn-info" style="border: 1px solid black;">
										<a style="color: black" href='/exposicion/nueva/<?= $imagen->getId() ?>'>
											<i class="fa fa-link"></i>
											AÑADIR
										</a>
									</td>
									<td class="btn btn-warning" style="border: 1px solid black;">
										<a style="color: black" href='/galeria/editar/<?= $imagen->getId() ?>'>
											<i class="fa fa-pencil"></i>
											EDITAR
										</a>
									</td>
									<td class="btn btn-danger" style="border: 1px solid black;">
										<a style="color: black" href='/galeria/borrar/<?= $imagen->getId() ?>' onclick="return confirm('¿Estás seguro?')">
											<i class="fa fa-trash"></i>
											ELIMINAR
										</a>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
